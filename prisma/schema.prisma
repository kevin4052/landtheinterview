generator client {
  provider = "prisma-client"
  output   = "../generated"
}

datasource db {
  provider = "postgresql"
}

model TailoredResume {
  id            String   @id @default(cuid())
  clerkUserId   String?
  resumeText    String
  jobText       String
  outputText    String
  inputFilename String?
  inputFormat   String?
  outputFormat  String?
  title         String?
  createdAt     DateTime @default(now())

  @@index([clerkUserId])
}
